---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

// タイトルを「メイン」と「サブ」に分割（全角コロン：で分割）
const titles = SITE_TITLE.split('：');
const mainTitle = titles[0];
const subTitle = titles.length > 1 ? '：' + titles[1] : '';
---

<header>
	<nav>
		<div class="header-top">
			<h2 class="logo">
				<a href="/">
					{mainTitle}
					<span class="sub-title">{subTitle}</span>
				</a>
			</h2>
			<button class="menu-toggle" aria-label="メニューを開く">
				<span class="hamburger"></span>
			</button>
		</div>

		<div class="header-main">
			<form action="/blog" method="GET" class="search-form">
				<input type="text" name="q" placeholder="気になるキーワードを入力" aria-label="ブログ内検索" />
				<button type="submit" aria-label="検索">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
				</button>
			</form>
			<div class="internal-links" id="menu">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/blog">Blog</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</div>
		</div>
	</nav>
</header>

<script>
	const menuToggle = document.querySelector('.menu-toggle');
	const headerMain = document.querySelector('.header-main');

	menuToggle?.addEventListener('click', () => {
		headerMain?.classList.toggle('is-open');
		menuToggle?.classList.toggle('is-active');
	});
</script>

<style>
	header {
		margin: 0;
		padding: 0;
		background: white;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
		position: sticky;
		top: 0;
		z-index: 1000;
	}
	nav {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		padding: 0.5rem 1rem;
	}

	/* ロゴとボタンの親要素：縦方向の中央で完璧に揃える */
	.header-top {
		width: 100%;
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center; /* 上下中央揃え */
		padding: 0.5rem 0;
	}

	.logo {
		margin: 0;
		line-height: 1.2;
		flex-grow: 1;
	}
	.logo a {
		color: var(--accent-dark);
		text-decoration: none;
		font-weight: 800;
		font-size: 1.25rem;
		display: block;
		line-height: 1.2;
	}
	.sub-title {
		font-size: 0.9rem;
		font-weight: 400;
		color: var(--gray);
		display: inline;
	}

	.header-main {
		width: 100%;
		display: flex;
		align-items: center;
		gap: 2rem;
		transition: all 0.3s ease;
	}

	/* 検索フォーム */
	.search-form {
		flex-grow: 1;
		display: flex;
		align-items: center;
		background: var(--gray-light);
		border-radius: 25px;
		padding: 0.2rem 1rem;
		border: 2px solid transparent;
		transition: border-color 0.2s;
	}
	.search-form input {
		width: 100%;
		border: none;
		background: transparent;
		padding: 0.5rem;
		font-size: 0.9rem;
		outline: none;
	}
	.search-form button {
		background: transparent;
		border: none;
		cursor: pointer;
		color: var(--gray);
		display: flex;
		align-items: center;
	}

	.internal-links {
		display: flex;
		gap: 1rem;
	}

	/* メニューボタン：サイズ固定 + 中央寄せ */
	.menu-toggle {
		display: none; /* PCでは隠す */
		background: none;
		border: none;
		cursor: pointer;
		width: 44px;
		height: 44px;
		padding: 0;
		align-items: center; /* 横並び時の中央 */
		justify-content: center; /* 縦並び時の中央 */
		margin-right: -10px; /* 右端ピッタリ寄せ */
	}

	.hamburger {
		display: block;
		width: 24px;
		height: 2px;
		background: var(--accent-dark);
		position: relative;
		transition: background 0.3s;
	}
	.hamburger::before,
	.hamburger::after {
		content: '';
		position: absolute;
		width: 24px;
		height: 2px;
		background: var(--accent-dark);
		transition: transform 0.3s;
	}
	.hamburger::before { top: -8px; }
	.hamburger::after { bottom: -8px; }

	.menu-toggle.is-active .hamburger { background: transparent; }
	.menu-toggle.is-active .hamburger::before { transform: rotate(45deg) translate(5px, 5px); }
	.menu-toggle.is-active .hamburger::after { transform: rotate(-45deg) translate(6px, -6px); }

	@media (max-width: 720px) {
		.menu-toggle {
			display: flex; /* スマホで表示 */
		}
		.logo a {
			font-size: 1.1rem;
		}
		.sub-title {
			display: none; /* スマホではサブタイトルを隠して1行に！ */
		}
		.header-main {
			display: none;
			flex-direction: column;
			gap: 1.2rem;
			padding: 1rem 0;
			border-top: 1px solid var(--gray-light);
		}
		.header-main.is-open {
			display: flex;
		}
		.internal-links {
			flex-direction: column;
			width: 100%;
			text-align: center;
		}
		.internal-links a {
			padding: 0.8rem;
			border-bottom: 1px solid var(--gray-light);
			width: 100%;
		}
	}
</style>
