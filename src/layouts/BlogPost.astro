---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { headings?: any[] };

const { title, description, pubDate, updatedDate, heroImage, category, headings } = Astro.props;
---

<html lang="ja">

	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				/* Full width on small screens, but we let blog-container handle the centering/grid */
				width: 100%;
				margin: 0;
			}
			.blog-container {
				display: flex;
				justify-content: center;
				gap: 2rem;
				max-width: 1100px;
				margin: 0 auto;
				padding: 0 1em;
			}
			.article-content {
				width: 760px;
				max-width: 100%;
			}
			.sidebar {
				display: none;
				width: 300px;
				flex-shrink: 0;
			}
			@media (min-width: 1024px) {
				.sidebar {
					display: block; /* Show the sidebar on PC */
				}
			}

			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.category-badge {
				display: inline-block;
				padding: 0.2em 0.8em;
				border-radius: 999px;
				background-color: var(--accent);
				color: white;
				font-size: 0.8rem;
				font-weight: bold;
				margin-bottom: 0.5em;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<div class="blog-container">
				<!-- 左側：メイン記事エリア -->
				<article class="article-content">
					<div class="hero-image">
						{
							heroImage && (
								typeof heroImage === 'string' ? (
									<img width={1020} height={510} src={heroImage} alt="" />
								) : (
									<Image width={1020} height={510} src={heroImage} alt="" />
								)
							)
						}
					</div>
					<div class="prose">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<div class="last-updated-on">
											Last updated on <FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
							{category && <div class="category-badge">{category}</div>}
							<h1>{title}</h1>
							<hr />
							
							{/* モバイル専用目次（タイトルの下に表示） */}
							{headings && headings.length > 0 && (
								<nav class="mobile-toc">
									<div class="toc-title">ここから飛べるケロ！🚀</div>
									<ul class="toc-list">
										{headings.map((heading) => (
											<li class={`toc-h${heading.depth}`}>
												<a href={`#${heading.slug}`}>{heading.text}</a>
											</li>
										))}
									</ul>
								</nav>
							)}
						</div>
						<slot />
					</div>
				</article>

				<!-- 右側：サイドバー（目次） -->
				{headings && headings.length > 0 && (
					<aside class="sidebar">
						<div class="toc-panel">
							<div class="toc-title">クリックでジャンプ 🐾</div>
							<ul class="toc-list">
								{headings.map((heading) => (
									<li class={`toc-h${heading.depth}`}>
										<a href={`#${heading.slug}`}>{heading.text}</a>
									</li>
								))}
							</ul>
						</div>
					</aside>
				)}
			</div>
		</main>
		<Footer />
	</body>
</html>
