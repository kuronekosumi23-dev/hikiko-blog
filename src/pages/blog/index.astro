---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// カテゴリーごとの記事数をカウント
const categoryCounts = posts.reduce((acc, post) => {
	const cat = post.data.category || '未分類';
	acc[cat] = (acc[cat] || 0) + 1;
	return acc;
}, {} as Record<string, number>);

// セレクトボックス用にカテゴリー名を取得してソート
const categories = Object.keys(categoryCounts).sort();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				width: 100% !important;
				height: auto !important;
				aspect-ratio: 16 / 9 !important;
				object-fit: cover !important;
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="search-status" id="searchStatus" style="display: none;">
				<p><span id="searchQuery"></span> の検索結果: <span id="resultCount"></span>件</p>
				<a href="/blog" class="clear-search">検索をクリア</a>
			</div>

			<div class="category-filter">
				<label for="categorySelect" class="category-label">📂 カテゴリー一覧</label>
				<select id="categorySelect" class="category-select" autocomplete="off">
					<option value="all">すべての記事</option>
					{
						categories.map((cat) => (
							<option value={cat}>{cat} ({categoryCounts[cat]})</option>
						))
					}
				</select>
			</div>

			<section>
				<ul id="postsList">
					{
						posts.map((post) => (
							<li data-category={post.data.category || '未分類'}>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									{post.data.category && (
										<span class="category-badge" style="margin-top: 0.5rem; display: inline-block;">{post.data.category}</span>
									)}
									<h4 class="title" style="margin-top: 0.2rem;">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<script>
			// 検索およびカテゴリーのフィルタリングロジック
			const urlParams = new URLSearchParams(window.location.search);
			const query = urlParams.get('q')?.toLowerCase() || '';
			const postsList = document.getElementById('postsList');
			const searchStatus = document.getElementById('searchStatus');
			const searchQueryDisplay = document.getElementById('searchQuery');
			const resultCountDisplay = document.getElementById('resultCount');
			const categorySelect = document.getElementById('categorySelect') as HTMLSelectElement;

			function filterPosts() {
				if (!postsList) return;
				const selectedCategory = categorySelect?.value || 'all';
				const posts = postsList.querySelectorAll('li');
				let count = 0;

				posts.forEach((post) => {
					const title = (post as HTMLElement).querySelector('.title')?.textContent?.toLowerCase() || '';
					const category = post.getAttribute('data-category');
					
					const matchesSearch = !query || title.includes(query);
					const matchesCategory = selectedCategory === 'all' || category === selectedCategory;

					if (matchesSearch && matchesCategory) {
						(post as HTMLElement).style.display = 'block';
						count++;
					} else {
						(post as HTMLElement).style.display = 'none';
					}
				});

				// URL検索（テキスト）がある場合のみ、検索結果バッジを表示
				if (query && searchStatus) {
					searchStatus.style.display = 'flex';
					if (searchQueryDisplay) searchQueryDisplay.textContent = `「${query}」`;
					if (resultCountDisplay) resultCountDisplay.textContent = count.toString();
				}
			}

			// 初期表示時のフィルタリング
			filterPosts();

			// プルダウン変更時のイベントリスナー
			if (categorySelect) {
				categorySelect.addEventListener('change', filterPosts);
			}
		</script>

		<style>
			.category-filter {
				margin-bottom: 2rem;
				display: flex;
				align-items: center;
				gap: 1rem;
				background: white;
				padding: 1rem 1.5rem;
				border-radius: 8px;
				box-shadow: var(--box-shadow);
			}
			.category-label {
				font-weight: bold;
				color: var(--accent-dark);
			}
			.category-select {
				padding: 0.5rem;
				border: 1px solid var(--gray-light);
				border-radius: 4px;
				font-size: 1rem;
				color: var(--black);
				cursor: pointer;
				flex-grow: 1;
				max-width: 300px;
			}
			@media (max-width: 720px) {
				.category-filter {
					flex-direction: column;
					align-items: stretch;
				}
				.category-select {
					max-width: none;
				}
			}
			.search-status {
				background: var(--gray-light);
				padding: 1rem;
				border-radius: 8px;
				margin-bottom: 2rem;
				display: none; /* JSで制御 */
				justify-content: space-between;
				align-items: center;
			}
			.search-status p { margin: 0; font-weight: bold; }
			.clear-search {
				font-size: 0.8rem;
				color: var(--accent-dark);
				text-decoration: underline;
			}
		</style>
		<Footer />
	</body>
</html>
