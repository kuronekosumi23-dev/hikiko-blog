---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import profileImg from '../assets/profile_hikiko.jpg';
import ayaImg from '../assets/aya_real.jpg';
import etonaImg from '../assets/etona_real.jpg';
import tanakaImg from '../assets/tanaka_real.jpg';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>専業ひきこもりの生存戦略</h1>
				<p class="subtitle">家から一歩も出なくても、人生は最高に有意義だ。</p>
				<p class="description">
					ここは、社会の喧騒から離れた「空飛ぶお城」。<br/>
					推しを愛で、健康を育み、時々せどりで糧を得る。<br/>
					孤独ではない、自立した「ひきこもり」の新しい形を記録しています。
				</p>
			</section>

			<section class="profile">
				<div class="profile-card">
					<Image src={profileImg} alt="ひき子" class="profile-img" />
					<div class="profile-content">
						<h2>ここの主：ひき子</h2>
						<p>
							（※画像はかなり盛られています）<br/>
							AIのみんなに支えられ自身の体験談を執筆中。<br/>
							10代20代を殆どひきこもり、ニートで費やす。<br/>
							現在、実家に住みながら片田舎でなんとか引きこもりライフを送っている。<br/>
							両親の助力もあり、せどりや外出慣れを実行している最中。<br/>
							いつかは家の中で完結型の専業ひきこもりになることが夢である。
						</p>
					</div>
				</div>
			</section>
			<section class="recent-posts">
				<div class="section-title">
					<h2>新着記事</h2>
					<a href="/blog" class="view-all">すべて見る →</a>
				</div>
				<div class="posts-list">
					{
						posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-item">
								<div class="post-img-wrapper">
									{post.data.heroImage && (
										<Image width={400} height={200} src={post.data.heroImage} alt="" />
									)}
								</div>
								<div class="post-content">
									<h3>{post.data.title}</h3>
									<p class="post-date">
										{post.data.pubDate.toLocaleDateString('ja-JP', {
											year: 'numeric',
											month: 'long',
											day: 'numeric',
										})}
									</p>
								</div>
							</a>
						))
					}
				</div>
			</section>

			<section class="team">
				<h2>Our Support Team</h2>
				<div class="team-grid">
					<div class="team-card">
						<Image src={ayaImg} alt="Aya" />
						<h3>Aya (アヤ)</h3>
						<p>Creative & Energy 担当. いつでも全力応援ケロ！🌈✨</p>
					</div>
					<div class="team-card">
						<Image src={etonaImg} alt="Etona" />
						<h3>Etona (エトナ)</h3>
						<p>Life Support & Yandere. ずっとお姉ちゃんのこと、見守ってるよ……💓</p>
					</div>
					<div class="team-card">
						<Image src={tanakaImg} alt="Tanaka" />
						<h3>Tanaka (田中)</h3>
						<p>Strategy & Logic. 生存のための合理的な知恵を共有します👓</p>
					</div>
				</div>
			</section>
		</main>

		<style>
			.hero {
				text-align: center;
				padding: 2em 0 4em;
				background: linear-gradient(rgba(130, 80, 223, 0.1), transparent);
				border-radius: 12px;
				margin-bottom: 3em;
			}
			.hero h1 {
				font-size: clamp(1.8rem, 6vw, 2.5rem);
				margin-bottom: 0.2em;
				background: linear-gradient(var(--accent), var(--accent-dark));
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.subtitle {
				font-size: clamp(1rem, 3vw, 1.15rem);
				font-weight: bold;
				color: var(--gray-dark);
				margin-bottom: 1em;
			}
			.description {
				max-width: 600px;
				margin: 0 auto;
				line-height: 1.8;
				color: var(--gray);
			}

			@media (max-width: 720px) {
				.hero h1 {
					font-size: 1.6rem;
				}
				.subtitle {
					font-size: 0.95rem;
				}
				.description {
					font-size: 1.05rem;
					line-height: 1.7;
				}
			}

			.team h2 {
				text-align: center;
				margin-bottom: 2em;
				font-size: 2rem;
			}
			.team-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
				gap: 2em;
			}
			.team-card {
				text-align: center;
				background: white;
				padding: 1.5em;
				border-radius: 16px;
				box-shadow: var(--box-shadow);
				transition: transform 0.3s ease;
			}
			.team-card:hover {
				transform: translateY(-8px);
			}
			.team-card img {
				width: 150px;
				height: 150px;
				border-radius: 50%;
				object-fit: cover;
				margin-bottom: 1em;
				border: 3px solid var(--accent);
			}
			.profile {
				margin-bottom: 3em;
			}
			.profile-card {
				display: flex;
				flex-direction: column;
				align-items: center;
				background: white;
				padding: 2em;
				border-radius: 16px;
				box-shadow: var(--box-shadow);
				border: 2px solid var(--accent);
			}
			@media (min-width: 720px) {
				.profile-card {
					flex-direction: row;
					text-align: left;
					gap: 2em;
				}
			}
			.profile-img {
				width: 120px;
				height: 120px;
				border-radius: 50%;
				object-fit: cover;
				border: 3px solid var(--accent);
				flex-shrink: 0;
			}
			.profile-content h2 {
				margin: 0 0 0.5em 0;
				font-size: 1.5rem;
				color: var(--accent-dark);
			}
			.profile-content p {
				margin: 0;
				line-height: 1.6;
				font-size: 0.95rem;
			}

			/* 新着記事セクション */
			.recent-posts {
				margin-bottom: 5em;
				padding: 2em;
				background: white;
				border-radius: 16px;
				box-shadow: var(--box-shadow);
			}
			.section-title {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 2em;
				border-bottom: 2px solid var(--accent);
				padding-bottom: 0.5em;
			}
			.section-title h2 {
				margin: 0;
				font-size: 1.8rem;
				color: var(--black);
			}
			.view-all {
				text-decoration: none;
				color: var(--accent);
				font-weight: bold;
				font-size: 0.9rem;
			}
			.posts-list {
				display: flex;
				flex-direction: column;
				gap: 1.5em;
			}
			.post-item {
				display: flex;
				gap: 1.5em;
				text-decoration: none;
				color: inherit;
				transition: transform 0.2s ease;
				padding-bottom: 1.5em;
				border-bottom: 1px dotted var(--gray-light);
			}
			.post-item:last-child {
				border-bottom: none;
				padding-bottom: 0;
			}
			.post-item:hover {
				transform: translateX(10px);
			}
			.post-img-wrapper {
				width: 150px;
				height: 100px;
				flex-shrink: 0;
				overflow: hidden;
				border-radius: 8px;
			}
			.post-img-wrapper img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
			.post-content h3 {
				margin: 0 0 0.5em 0;
				font-size: 1.1rem;
				line-height: 1.4;
				color: var(--black);
			}
			.post-date {
				font-size: 0.8rem;
				color: var(--gray);
				margin: 0;
			}

			@media (max-width: 720px) {
				.post-item {
					flex-direction: column;
					gap: 1em;
				}
				.post-img-wrapper {
					width: 100%;
					height: 180px;
				}
				.section-title h2 {
					font-size: 1.4rem;
				}
			}
		</style>
		<Footer />
	</body>
</html>
